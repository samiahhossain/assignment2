# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── MySQL (Railway) ───────────────────────────────────────────────────────────
# Paste the full Railway DATABASE_URL, or fill in the individual fields below.
DATABASE_URL=mysql://USER:PASSWORD@HOST:PORT/intellicare

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=900
REFRESH_TOKEN_EXPIRES_IN=604800

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,https://intellicare.vercel.app
